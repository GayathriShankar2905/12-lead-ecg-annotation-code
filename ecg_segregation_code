        diagnose_dataset(ds_name, root, n=5)

ds_record_counts = {}
ds_code_counts   = {}
combined_counts  = collections.defaultdict(int)
all_unmapped     = collections.Counter()

for ds_name, root in DATASETS.items():
    if not os.path.isdir(root):
        print(f"[SKIP] {ds_name} — root not found: {root}")
        ds_record_counts[ds_name] = {}
        continue

    hea_files = sorted(set(
        glob.glob(os.path.join(root, "**/*.hea"), recursive=True) +
        glob.glob(os.path.join(root, "*.hea"))
    ))

    class_counts = collections.defaultdict(int)
    code_counter = collections.Counter()

    for hp in hea_files:
        dx  = parse_dx(hp)
        cls = snomed_to_class(dx)
        class_counts[cls] += 1
        combined_counts[cls]  += 1
        code_counter.update(dx)
        for c in dx:
            if c not in ALL_KNOWN:
                all_unmapped[c] += 1

    ds_record_counts[ds_name] = dict(class_counts)
    ds_code_counts[ds_name]   = code_counter
    print(f"[{ds_name}] scanned {sum(class_counts.values())} records  "
          f"| unknown: {class_counts.get(-1,0)}")


