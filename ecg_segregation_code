# ============================================================
# COMBINED LOOKUP AND CLASS NAMES
# ============================================================
ALL_KNOWN  = NORMAL_CODES | MI_CODES | MIMIC_CODES | OTHER_CODES
CLASS_NAMES = {0: "Normal", 1: "MI", 2: "Mimic", 3: "Other", -1: "Unknown"}

# Priority: MI > Mimic > Other > Normal > Unknown
def snomed_to_class(dx_codes):
    s = set(dx_codes)
    if s & MI_CODES:     return 1
    if s & MIMIC_CODES:  return 2
    if s & OTHER_CODES:  return 3
    if s & NORMAL_CODES: return 0
    return -1


# ============================================================
# ROBUST .hea PARSER
# Handles every #Dx variant seen across PhysioNet datasets:
#   #Dx: 270492004,164889003
#   # Dx: 270492004
#   #Dx 270492004,164889003
#   #dx:270492004
# Also accepts 5-digit codes (some CPSC codes are 5 digits).
# ============================================================
def parse_dx(hea_path):
    try:
        with open(hea_path, encoding="utf-8", errors="replace") as f:
            for line in f:
                stripped = line.strip()
                # Match any line whose comment starts with #dx (case-insensitive)
                if re.match(r'#\s*dx', stripped, re.IGNORECASE):
                    # Strip the '#dx' prefix (with optional spaces and colon)
                    rest = re.sub(r'^#\s*dx\s*:?\s*', '', stripped, flags=re.IGNORECASE)
                    # Extract all digit runs of 5+ digits (SNOMED codes are 6–18 digits;
                    # some CPSC codes are 5-digit — keep >=5 to be safe)
                    codes = re.findall(r'\b\d{5,}\b', rest)
                    if codes:
                        return codes
    except Exception:
        pass
    return []


# ============================================================
# DEBUG HELPER — call once on a dataset to diagnose issues
# ============================================================
def diagnose_dataset(ds_name, root, n=5):
    """Print the raw #Dx (or equivalent) lines from the first n .hea files."""
    hea_files = sorted(
        set(glob.glob(os.path.join(root, "**/*.hea"), recursive=True) +
            glob.glob(os.path.join(root, "*.hea")))
    )[:n]
    print(f"\n{'='*60}")
    print(f"DIAGNOSTICS — {ds_name}  (first {n} records)")
    print(f"{'='*60}")
    for hp in hea_files:
        print(f"\n  File: {hp}")
        try:
            with open(hp, encoding="utf-8", errors="replace") as f:
                lines = f.readlines()
            comment_lines = [l.rstrip() for l in lines if l.strip().startswith('#')]
            if comment_lines:
                for cl in comment_lines:
                    print(f"    {cl}")
            else:
                print("    (no comment lines found — showing last 3 lines)")
                for l in lines[-3:]:
                    print(f"    {l.rstrip()}")
        except Exception as e:
            print(f"    ERROR: {e}")
    print(f"\n{'='*60}\n")


